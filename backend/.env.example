# ============================================================
# Master AI Yönetmen — .env anahtarları
# ============================================================

APP_NAME=Master AI Yönetmen
DEBUG=true
DATABASE_URL=sqlite:///./data/app.db

# Güvenlik
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

INITIAL_CREDITS=10
ADMIN_EMAIL=yazelkaraemail69@gmail.com

# --- MOCK: true iken gerçek API çağrılmaz (geliştirme) ---
MOCK_AI=true

# ============================================================
# AI 1 — Senaryo Uzmanı (OpenRouter / Claude)
# https://openrouter.ai/keys
# ============================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ============================================================
# AI 2 — Görsel Tasarımcı (OpenRouter image: Flux / DALL·E)
# Aynı OPENROUTER_API_KEY kullanılır
# ============================================================
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-pro
IMAGE_WIDTH=768
IMAGE_HEIGHT=1344

# ============================================================
# Ses — ElevenLabs (AI3 kurguya girer)
# https://elevenlabs.io/app/settings/api-keys
# ============================================================
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# AI 3 — Kurgu: imageio-ffmpeg (ek anahtar yok)

PRODUCE_CREDIT_COST=1
REFINE_CREDIT_COST=1
MEDIA_DIR=./data/media

# Not: Kullanıcı Ayarlar panelinden de OpenRouter / ElevenLabs
# anahtarı kaydedebilir (şifreli DB). .env sunucu fallback'idir.

COPY_UNLOCK_CREDIT_COST=1
