# ============================================================
# Shorts Video Oluşturucu — .env anahtarları
# ============================================================

APP_NAME=Shorts Video Oluşturucu
DEBUG=true
DATABASE_URL=sqlite:///./data/app.db

# Güvenlik
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Kayıt bonusu ≈ 1 tam 30sn Shorts (senaryo 15 + üret 100)
INITIAL_CREDITS=130
ADMIN_EMAIL=

# --- MOCK: true iken gerçek API çağrılmaz (geliştirme) ---
MOCK_AI=true

# ============================================================
# AI 1–3 — Senaryo konseyi (OpenRouter — Sonnet 4.6 önerilir)
# ============================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_CHALLENGER=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_AUDITOR=anthropic/claude-sonnet-4.6

# ============================================================
# AI 4 — Kaynak tarayıcı (Anthropic doğrudan — Sonnet 4.6)
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# AI 2 — Görsel (Flux.2 Pro ~$0.045 / 9:16 sahne)
# ============================================================
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-pro
IMAGE_WIDTH=768
IMAGE_HEIGHT=1344

# ============================================================
# Ses — ElevenLabs multilingual v2 (~$0.10 / 1K karakter)
# ============================================================
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Kredi fiyatları (1 kredi ≈ $0.01 perakende, ~3.5× COGS marj)
SCENARIO_CREDIT_COST=15
PRODUCE_CREDIT_COST=100
DISCUSS_CREDIT_COST=10
REFINE_CREDIT_COST=35
COPY_UNLOCK_CREDIT_COST=5

MEDIA_DIR=./data/media
